{
	admin off
	auto_https off
	persist_config off
}

# FEN-1594 — isolated neobrutalism preview served on a liveplace.tv SUBPATH.
# Coolify/Traefik routes only Host(liveplace.tv) && PathPrefix(/preview/
# fen-1580-neobrutalism) to this container. Whether Traefik strips the prefix or
# forwards it is version-dependent, so serve robustly for BOTH: the static tree
# lives under /srv/preview/fen-1580-neobrutalism and try_files tries the path
# as-is (prefix forwarded) AND re-prefixed (prefix stripped), then the SPA
# index.html for client-router routes (e.g. .../fenysk).
:80 {
	header X-Robots-Tag "noindex, nofollow"
	header Content-Security-Policy "default-src 'self'; base-uri 'none'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://static-cdn.jtvnw.net; font-src 'self' data:; connect-src 'self' https://liveplace.tv wss://liveplace.tv"
	header X-Content-Type-Options "nosniff"

	# Container-internal healthcheck (Coolify hits this directly, not via Traefik).
	handle /healthz {
		respond "ok" 200
	}

	handle {
		root * /srv
		try_files {path} /preview/fen-1580-neobrutalism{path} /preview/fen-1580-neobrutalism/index.html
		file_server
	}
}
